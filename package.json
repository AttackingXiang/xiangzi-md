{
  "name": "xiangzi-md",
  "private": true,
  "version": "1.6.18",
  "description": "Xiangzi MD — 一个本地优先、所见即所得的 Markdown 编辑器",
  "author": "guoxiangzi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AttackingXiang/xiangzi-md.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --pretty false && tsc -p tsconfig.node.json --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "knip": "knip",
    "check": "npm run format:check && npm run lint && npm run test:run && npm run build",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --locked -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "rust:check": "npm run rust:fmt && npm run rust:lint && npm run rust:test",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-sql": "6.10.0",
    "@codemirror/lang-xml": "6.1.0",
    "@codemirror/lang-yaml": "6.1.3",
    "@codemirror/language": "6.12.3",
    "@codemirror/language-data": "6.5.2",
    "@codemirror/legacy-modes": "6.5.3",
    "@codemirror/search": "6.7.1",
    "@codemirror/state": "6.7.0",
    "@codemirror/view": "6.43.2",
    "@lezer/highlight": "1.2.3",
    "@milkdown/crepe": "7.21.2",
    "@milkdown/kit": "7.21.2",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "fast-png": "8.0.0",
    "html2canvas-pro": "2.2.0",
    "jpeg-js": "0.4.4",
    "jspdf": "4.2.1",
    "lucide-react": "0.468.0",
    "mermaid": "11.15.0",
    "prosemirror-history": "1.5.0",
    "prosemirror-search": "1.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "2.11.3",
    "@types/node": "22.20.0",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "knip": "6.25.0",
    "prettier": "3.8.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
