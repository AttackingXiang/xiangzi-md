{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Xiangzi MD",
  "version": "2.0.1",
  "identifier": "com.guoxiangzi.xiangzimd",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Xiangzi MD",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost xmd: http://xmd.localhost; img-src 'self' xmd: http://xmd.localhost asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFMTlCNTZENTU3QUEwMzAKUldRd29IcFZiYlVaVGhkUFZTSURCaXJrTExzdEp5c0VuM3VpNFBscFM3eTN0ZGFWSEVTY3RwYWIK",
      "endpoints": [
        "https://github.com/AttackingXiang/xiangzi-md/releases/latest/download/latest.json",
        "https://gitee.com/tlqgyx/xiangzi-md/raw/updater/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
